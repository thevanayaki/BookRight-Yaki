<script>
const HOUR_HEIGHT = 54;
const START_HOUR = 8;
const HOURS = 11;

const grid = document.getElementById('grid');
const tracks = grid.querySelectorAll('.day-track');

tracks.forEach(t => {
  for(let h = 0; h < HOURS; h++){
    const div = document.createElement('div');
    div.className = 'hour-line';
    t.appendChild(div);
  }
});

function timeToTop(h, m=0){
  return (h - START_HOUR + m/60) * HOUR_HEIGHT;
}
function durationToHeight(startH, startM, endH, endM){
  return ((endH - startH) + (endM - startM)/60) * HOUR_HEIGHT;
}

const bookings = [
  {day:0, sh:11, sm:0, eh:11, em:0, label:'Fysioterapi', time:'11:00-11:00', type:'blue'},
  {day:0, sh:13, sm:0, eh:14, em:0, label:'Sportsmassage', time:'13:00-14:00', type:'green'},
  {day:0, sh:15, sm:0, eh:17, em:30, label:'Fysioterapi', time:'15:00-15:00', type:'blue'},

  {day:1, sh:10, sm:0, eh:12, em:0, label:'Fysioterapi', time:'10:00-12:00', type:'blue'},
  {day:1, sh:12, sm:0, eh:13, em:0, label:'Sportsmassage', time:'12:00-13:00', type:'green'},
  {day:1, sh:15, sm:0, eh:16, em:30, label:'Sportsmassage', time:'15:00-15:00', type:'green'},

  {day:2, sh:9, sm:0, eh:12, em:0, label:'Fysioterapi', time:'10:00-12:00', type:'blue'},
  {day:2, sh:11, sm:0, eh:12, em:0, label:'Fysioterapi', time:'11:00-11:00', type:'blue'},
  {day:2, sh:14, sm:0, eh:17, em:0, label:'Akupunktur', time:'15:00-15:00', type:'orange'},

  {day:3, sh:10, sm:0, eh:12, em:0, label:'Fysioterapi', time:'10:00-12:00', type:'blue'},
  {day:3, sh:13, sm:0, eh:14, em:0, label:'Sportsmassage', time:'13:00-14:00', type:'green'},
  {day:3, sh:15, sm:0, eh:15, em:30, label:'Fysioterapi', time:'15:00-15:00', type:'blue'},
  {day:3, sh:17, sm:0, eh:18, em:0, label:'Akupunktur', time:'17:00-18:00', type:'orange'},

  {day:4, sh:13, sm:0, eh:14, em:0, label:'Sportsmassage', time:'13:00-14:00', type:'green'},
  {day:4, sh:15, sm:0, eh:18, em:0, label:'Akupunktur', time:'15:00-18:00', type:'orange'},
  {day:4, sh:18, sm:0, eh:18, em:30, label:'Fysioterapi', time:'18:00-18:00', type:'blue'},
];

bookings.forEach(b => {
  const track = document.getElementById('d' + b.day);
  const div = document.createElement('div');
  div.className = 'booking b-' + b.type;
  const top = timeToTop(b.sh, b.sm);
  const minH = 28;
  const h = Math.max(durationToHeight(b.sh, b.sm, b.eh, b.em), minH);
  div.style.top = top + 'px';
  div.style.height = h + 'px';
  div.innerHTML = '<div class="booking-title">' + b.label + '</div><div class="booking-time">' + b.time + '</div>';
  track.appendChild(div);
});

grid.style.height = (HOURS * HOUR_HEIGHT) + 'px';
</script>
